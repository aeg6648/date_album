{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    { "source": "/dates/2026-04-26_hangang", "destination": "/date?id=2026-04-26-hangang", "permanent": false },
    { "source": "/Edit", "destination": "/edit", "permanent": false },
    { "source": "/EDIT", "destination": "/edit", "permanent": false },
    { "source": "/Date", "destination": "/date", "permanent": false },
    { "source": "/DATE", "destination": "/date", "permanent": false },
    { "source": "/admin", "destination": "/edit", "permanent": false },
    { "source": "/admin/", "destination": "/edit", "permanent": false }
  ]
}
